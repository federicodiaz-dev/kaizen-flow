# Google AI Studio multi-agent assistant
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash
GOOGLE_ROUTER_MODEL=gemini-2.5-flash-lite
AI_DEFAULT_SITE_ID=MLA
AI_HISTORY_WINDOW=8
AI_MEMORY_DIR=backend/data/agents
AI_TOKEN_REPORT_ENABLED=true
AI_TOKEN_REPORT_DIR=backend/data/ai_usage_reports
AI_TOKEN_REPORT_BUDGET_TOKENS=
