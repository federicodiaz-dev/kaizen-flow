ML_APP_ID=
ML_CLIENT_SECRET=
ML_REDIRECT_URI=https://api.tudominio.com/api/auth/mercadolibre/callback
ML_AUTH_BASE=https://api.mercadolibre.com
ML_OAUTH_AUTHORIZE_URL=https://auth.mercadolibre.com.ar/authorization
ML_API_BASE=https://api.mercadolibre.com

FRONTEND_ORIGIN=http://localhost:4200
LANDING_ORIGIN=http://localhost:8000
PUBLIC_APP_URL=http://localhost:4200
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://localhost:8000
TRUSTED_HOSTS=localhost,127.0.0.1

APP_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kaizen_flow
APP_DB_PATH=backend/data/kaizen_flow.sqlite3
APP_ENCRYPTION_KEY=
PASSWORD_PEPPER=
DEFAULT_PLAN_CODE=growth

SESSION_COOKIE_NAME=kaizen_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_DOMAIN=
SESSION_TTL_HOURS=336
CSRF_COOKIE_NAME=kaizen_csrf
CSRF_COOKIE_SECURE=false
CSRF_COOKIE_SAME_SITE=lax
CSRF_COOKIE_DOMAIN=
AUTH_RATE_LIMIT_REQUESTS=8
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
CHECKOUT_RATE_LIMIT_REQUESTS=12
CHECKOUT_RATE_LIMIT_WINDOW_SECONDS=300
SECURITY_HEADERS_ENABLED=true
SERVE_LANDING_FROM_BACKEND=true

# Groq multi-agent assistant
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_ROUTER_MODEL=openai/gpt-oss-20b
AI_DEFAULT_SITE_ID=MLA
AI_HISTORY_WINDOW=8
AI_MEMORY_DIR=backend/data/agents
AI_TOKEN_REPORT_ENABLED=true
AI_TOKEN_REPORT_DIR=backend/data/ai_usage_reports
AI_TOKEN_REPORT_BUDGET_TOKENS=
AI_TOKEN_REPORT_BUDGET_WINDOW=monthly

# Optional Mercado Libre MCP
AI_MCP_ENABLED=false
AI_MCP_SERVER_NAME=mercadolibre
AI_MCP_TRANSPORT=http
AI_MCP_URL=
AI_MCP_COMMAND=
AI_MCP_ARGS_JSON=[]
# Extra headers only. Authorization is resolved automatically from the active/default ML account.
AI_MCP_HEADERS_JSON={}
AI_MCP_ENV_JSON={}
AI_MCP_CWD=

# Legacy SQLite path is kept only for one-time migration into PostgreSQL.
